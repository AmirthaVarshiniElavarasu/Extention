/**
 * Example Configuration File
 * Copy this to your VS Code settings.json under the [emailToSheet] namespace
 */

{
  "emailToSheet.emailProvider": "gmail",
  
  // Sync timing configuration
  "emailToSheet.syncInterval": 15,
  "emailToSheet.maxEmails": 100,
  "emailToSheet.autoSync": false,
  "emailToSheet.enableNotifications": true,

  // Email filter rules - add as many as needed
  "emailToSheet.filterRules": [
    {
      "name": "Work Emails",
      "type": "sender",
      "value": "@company.com",
      "enabled": true
    },
    {
      "name": "With Attachments",
      "type": "hasAttachment",
      "value": "true",
      "enabled": false
    },
    {
      "name": "Specific Subject",
      "type": "subject",
      "value": "Invoice",
      "enabled": true
    },
    {
      "name": "Gmail Label",
      "type": "label",
      "value": "Important",
      "enabled": false
    },
    {
      "name": "Recent Emails",
      "type": "date",
      "value": "2024-01-01",
      "enabled": true
    }
  ],

  // Column mapping - map email fields to sheet columns
  "emailToSheet.columnMapping": {
    "from": "A",
    "to": "B",
    "subject": "C",
    "date": "D",
    "body": "E",
    "attachments": "F",
    "labels": "G"
  },

  // Google Sheets settings
  "emailToSheet.sheetSettings": {
    "spreadsheetId": "1a2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p7q8r9s0t",
    "sheetName": "Emails",
    "appendMode": true,
    "includeHeaders": true
  },

  // Optional: Enable debug logging
  "emailToSheet.debug": false
}

