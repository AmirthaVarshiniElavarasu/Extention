{
  "presets": [
    [
      "@babel/preset-env",
      {
        "targets": {
          "chrome": "88"
        },
        "modules": "auto",
        "useBuiltIns": "entry",
        "corejs": "3.33.0"
      }
    ]
  ],
  "plugins": [
    "@babel/plugin-proposal-class-properties",
    "@babel/plugin-proposal-private-methods"
  ],
  "env": {
    "production": {
      "plugins": [
        "transform-remove-console"
      ]
    }
  }
}
